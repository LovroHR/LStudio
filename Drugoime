import torch
import torchvision
from time import time
from torch.utils.data import DataLoader, random_split
from torch.utils.tensorboard import SummaryWriter
from torchvision import datasets, transforms
from torch import nn, optim

if __name__ == '__main__':
    cuda = True if torch.cuda.is_available() else False
    device = torch.device('cuda' if cuda else 'cpu')
    print("Koristi se uređaj:", device)

    # Transformacije
    transform = torchvision.transforms.Compose([
        transforms.ToTensor(),
        transforms.Normalize((0.5,), (0.5,))
    ])

    # EMNIST Letters ima labele 1-26, a trebaju biti 0-25
    target_transform = lambda y: y - 1

    # Učitavanje EMNIST Letters
    full_trainset = datasets.EMNIST(
        'emnist_data',
        split='letters',
        download=True,
        train=True,
        transform=transform,
        target_transform=target_transform
    )

    testset = datasets.EMNIST(
        'emnist_data',
        split='letters',
        download=True,
        train=False,
        transform=transform,
        target_transform=target_transform
    )

    # Validation split
    val_size = int(0.1 * len(full_trainset))
    train_size = len(full_trainset) - val_size
    trainset, valset = random_split(full_trainset, [train_size, val_size])

    train_loader = DataLoader(trainset, batch_size=256, shuffle=True, num_workers=2, pin_memory=True)
    val_loader = DataLoader(valset, batch_size=256, shuffle=False, num_workers=2, pin_memory=True)
    test_loader = DataLoader(testset, batch_size=256, shuffle=False, num_workers=2, pin_memory=True)

    # Dimenzije
    input_size = 784
    output_size = 26

    # Model - samo linearni slojevi
    model = nn.Sequential(
        nn.Linear(input_size, 1024),
        nn.ReLU(),
        nn.Dropout(0.3),

        nn.Linear(1024, 512),
        nn.ReLU(),
        nn.Dropout(0.2),

        nn.Linear(512, 256),
        nn.ReLU(),

        nn.Linear(256, output_size)
    ).to(device)

    # Loss i optimizer
    loss_fn = nn.CrossEntropyLoss().to(device)
    optimizer = optim.Adam(model.parameters(), lr=0.001, weight_decay=1e-4)

    # TensorBoard
    writer = SummaryWriter("runs/emnist_letters")

    # Treniranje
    best_val_acc = 0.0
    epochs = 20
    time0 = time()

    for e in range(epochs):
        model.train()
        running_loss = 0.0
        correct_train = 0
        total_train = 0

        for images, labels in train_loader:
            images = images.to(device, non_blocking=True).view(images.shape[0], -1)
            labels = labels.to(device, non_blocking=True)

            optimizer.zero_grad()
            outputs = model(images)
            loss = loss_fn(outputs, labels)
            loss.backward()
            optimizer.step()

            running_loss += loss.item()
            _, preds = torch.max(outputs, 1)
            correct_train += (preds == labels).sum().item()
            total_train += labels.size(0)

        train_loss = running_loss / len(train_loader)
        train_acc = correct_train / total_train

        # Validacija
        model.eval()
        val_loss = 0.0
        correct_val = 0
        total_val = 0

        with torch.no_grad():
            for images, labels in val_loader:
                images = images.to(device, non_blocking=True).view(images.shape[0], -1)
                labels = labels.to(device, non_blocking=True)

                outputs = model(images)
                loss = loss_fn(outputs, labels)

                val_loss += loss.item()
                _, preds = torch.max(outputs, 1)
                correct_val += (preds == labels).sum().item()
                total_val += labels.size(0)

        val_loss /= len(val_loader)
        val_acc = correct_val / total_val

        print(f"Epoch {e+1}/{epochs} | "
              f"Train loss: {train_loss:.4f} | Train acc: {train_acc:.4f} | "
              f"Val loss: {val_loss:.4f} | Val acc: {val_acc:.4f}")

        writer.add_scalar("Loss/train", train_loss, e)
        writer.add_scalar("Accuracy/train", train_acc, e)
        writer.add_scalar("Loss/val", val_loss, e)
        writer.add_scalar("Accuracy/val", val_acc, e)

        if val_acc > best_val_acc:
            best_val_acc = val_acc
            torch.save(model.state_dict(), "best_emnist_letters.pth")
            print("Spremljen najbolji model.")

    print("\nTrenirali smo (u minutama):", (time() - time0) / 60)

    # Učitavanje najboljeg modela za test
    model.load_state_dict(torch.load("best_emnist_letters.pth"))
    model.eval()

    num_correct = 0
    num_samples = 0

    with torch.no_grad():
        for images, labels in test_loader:
            images = images.to(device, non_blocking=True).view(images.shape[0], -1)
            labels = labels.to(device, non_blocking=True)

            outputs = model(images)
            _, predictions = outputs.max(1)

            num_correct += (predictions == labels).sum().item()
            num_samples += labels.size(0)

    test_acc = num_correct / num_samples

    print(f"\nBroj testiranih slika = {num_samples}")
    print(f"Točnost modela na test skupu = {test_acc * 100:.2f}%")

    writer.add_scalar("Accuracy/test", test_acc)
    writer.close()

    print("\nPokreni TensorBoard naredbom:")
    print("tensorboard --logdir=runs")
